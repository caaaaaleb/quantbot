# Binance API 配置
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# 交易配置
SYMBOL=BTC/USDT
TIMEFRAME=1m
POSITION_SIZE=0.2  # 单笔仓位比例 (20%)
STOP_LOSS=0.02     # 止损比例 (2%)
TAKE_PROFIT=0.05   # 止盈比例 (5%)

# 策略参数
MA_SHORT=5
MA_LONG=20
STRATEGY_INTERVAL=60  # 策略执行间隔（秒）

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/quantbot.log
